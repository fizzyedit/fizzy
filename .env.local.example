# Copy to `.env.local` (gitignored) and fill in your own identities.
# `zig build package -Dtarget=*-macos` will pick these up automatically.
#
# To find your identities:
#   security find-identity -v
#
# To create a notarytool keychain profile (one-time):
#   xcrun notarytool store-credentials <profile-name> \
#     --apple-id <your-apple-id> \
#     --team-id <YOUR_TEAM_ID> \
#     --password <app-specific-password>

export PIXI_MACOS_SIGN_APP="Developer ID Application: Your Name (TEAMID)"
export PIXI_MACOS_SIGN_INSTALLER="Developer ID Installer: Your Name (TEAMID)"
export PIXI_MACOS_NOTARY_PROFILE="your-profile-name"

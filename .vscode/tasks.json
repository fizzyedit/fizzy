{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "options": {
        "env": {
            // Cursor's terminal sandbox redirects NuGet restore to a cache dir
            // that drops loose vendor binaries (UpdateMac, setup.exe, etc.) from
            // the vpk package, so `dotnet vpk pack` fails with "HelperFile could
            // not find 'UpdateMac'". Force restore to write to the real per-user
            // cache where the binaries land correctly.
            "NUGET_PACKAGES": "${env:HOME}/.nuget/packages",
            "ZIG_SYSTEM_LINKER_HACK": "1",
            "MTL_SHADER_VALIDATION": "1",
            "MTL_SHADER_VALIDATION_GLOBAL_MEMORY": "1",
            "MTL_SHADER_VALIDATION_TEXTURE_USAGE": "1",
            "MTL_DEBUG_LAYER": "1",
            "METAL_DEVICE_WRAPPER_TYPE": "1",
            "MTL_DEBUG_LAYER_VALIDATE_LOAD_ACTIONS": "1",
            "MTL_DEBUG_LAYER_VALIDATE_UNRETAINED_RESOURCES": "0x4",
        },
    },
    "tasks": [
        {
            "label": "Build Project",
            "type": "shell",
            "command": "zig build -Dno-emit",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "clear": true
            }
        },
        {
            "label": "Build and Run Project",
            "type": "shell",
            "command": "zig build run",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "clear": true
            }
        },
        {
            "label": "Build and Run Project (release-fast)",
            "type": "shell",
            "command": "zig build run -Doptimize=ReleaseFast",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "clear": true
            }
        },
        {
            "label": "Build and Run Project (release-small)",
            "type": "shell",
            "command": "zig build run -Doptimize=ReleaseSmall",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "clear": true
            }
        },
        {
            "label": "Build and Run Project (release-safe)",
            "type": "shell",
            "command": "zig build run -Doptimize=ReleaseSafe",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "clear": true
            }
        },
        {
            "label": "Test Project",
            "type": "shell",
            "command": "zig build test",
            "group": {"kind": "build", "isDefault": true},
            "presentation": {
                "clear": true,
            },
        },
        {
            "label": "Test File",
            "type": "shell",
            "command": "zig test ${file}",
            "presentation": {
                "clear": true
            },
            "group": {"kind": "build", "isDefault": true},
        },
        {
            "label": "Process Assets",
            "type": "shell",
            "command": "zig build process-assets",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "clear": true
            }
        },
        {
            "label": "Update dependencies",
            "type": "shell",
            "command": "zig build update -Dno-emit",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "clear": true
            }
        },
        {
            "label": "MSVC SDK (msvcup-setup, macOS/Linux/Windows)",
            "type": "shell",
            "command": "zig build msvcup-setup",
            "group": "build",
            "presentation": {
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "Install (release-fast)",
            "type": "shell",
            "command": "zig build install -Doptimize=ReleaseFast",
            "group": "build",
            "presentation": {
                "clear": true
            }
        },
        {
            "label": "Package (Velopack)",
            "type": "shell",
            "command": "[ -f .env.local ] && set -a && . ./.env.local && set +a; zig build package -Doptimize=ReleaseFast",
            "windows": {
                "command": "zig build package -Doptimize=ReleaseFast"
            },
            "group": {"kind": "build", "isDefault": true},
            "presentation": {
                "clear": true
            }
        },
        {
            "label": "Run Release Script (skip build, reuse zig-out)",
            "type": "shell",
            "command": "[ -f .env.local ] && set -a && . ./.env.local && set +a; FIZZY_RELEASE_SKIP_BUILD=1 scripts/release.sh",
            "windows": {
                "command": "$env:FIZZY_RELEASE_SKIP_BUILD='1'; bash scripts/release.sh"
            },
            "group": {"kind": "build", "isDefault": true},
            "presentation": {
                "clear": true
            }
        },
        {
            "label": "Package (Velopack): Linux x86_64",
            "type": "shell",
            "command": "zig build package -Doptimize=ReleaseFast -Dtarget=x86_64-linux-gnu",
            "group": {"kind": "build", "isDefault": true},
            "presentation": {
                "clear": true
            }
        },
        {
            "label": "Package (Velopack): Linux aarch64",
            "type": "shell",
            "command": "zig build package -Doptimize=ReleaseFast -Dtarget=aarch64-linux-gnu",
            "group": {"kind": "build", "isDefault": true},
            "presentation": {
                "clear": true
            }
        },
        {
            "label": "Package (Velopack): macOS x86_64",
            "type": "shell",
            "command": "[ -f .env.local ] && set -a && . ./.env.local && set +a; zig build package -Doptimize=ReleaseFast -Dtarget=x86_64-macos",
            "windows": {
                "command": "zig build package -Doptimize=ReleaseFast -Dtarget=x86_64-macos"
            },
            "group": {"kind": "build", "isDefault": true},
            "presentation": {
                "clear": true
            }
        },
        {
            "label": "Package (Velopack): macOS aarch64",
            "type": "shell",
            "command": "[ -f .env.local ] && set -a && . ./.env.local && set +a; zig build package -Doptimize=ReleaseFast -Dtarget=aarch64-macos",
            "windows": {
                "command": "zig build package -Doptimize=ReleaseFast -Dtarget=aarch64-macos"
            },
            "group": {"kind": "build", "isDefault": true},
            "presentation": {
                "clear": true
            }
        },
        {
            "label": "Package (Velopack): Windows x86_64 (MSVC)",
            "type": "shell",
            "command": "zig build package -Doptimize=ReleaseFast -Dtarget=x86_64-windows-msvc -Dfetch-msvc",
            "group": {"kind": "build", "isDefault": true},
            "presentation": {
                "clear": true
            }
        },
        {
            "label": "Package (Velopack): Windows aarch64 (MSVC)",
            "type": "shell",
            "command": "zig build package -Doptimize=ReleaseFast -Dtarget=aarch64-windows-msvc -Dfetch-msvc",
            "group": {"kind": "build", "isDefault": true},
            "presentation": {
                "clear": true
            }
        },
        {
            "label": "Package (Velopack): all 6 targets",
            "type": "shell",
            "command": "[ -f .env.local ] && set -a && . ./.env.local && set +a; zig build packageall -Doptimize=ReleaseFast",
            "windows": {
                "command": "zig build packageall -Doptimize=ReleaseFast"
            },
            "group": {"kind": "build", "isDefault": true},
            "presentation": {
                "clear": true
            }
        },
    ],
    "inputs": [
        {
            "id": "zigTarget",
            "type": "command",
            "command": "zig.build.getTargets",
        },
        {
            "id": "zigLastTarget",
            "type": "command",
            "command": "zig.build.getLastTargetOrPrompt"
        }
    ]
}
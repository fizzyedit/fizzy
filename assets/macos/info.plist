<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleName</key>
	<string>fizzy</string>
	<key>CFBundleDisplayName</key>
	<string>fizzy</string>
	<key>CFBundleIdentifier</key>
	<string>com.foxnne.fizzy</string>
	<key>CFBundleShortVersionString</key>
	<string>0.1.0</string>
	<key>CFBundleVersion</key>
	<string>0.1.0</string>
	<key>CFBundleIconFile</key>
	<string>fizzy.icns</string>
	<!--
	  Required for Gatekeeper / `spctl --assess` to recognise the bundle as an
	  application after notarisation. Without `CFBundlePackageType=APPL` +
	  `CFBundleExecutable`, vpk's post-notarise spctl check fails with
	  "the code is valid but does not seem to be an app".
	-->
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleExecutable</key>
	<string>fizzy</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>LSMinimumSystemVersion</key>
	<string>11.0</string>
	<key>NSHighResolutionCapable</key>
	<true/>
	<key>CFBundleDocumentTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeExtensions</key>
			<array>
				<string>fiz</string>
				<string>pixi</string>
				<string>png</string>
				<string>jpg</string>
				<string>jpeg</string>
			</array>
			<key>CFBundleTypeIconFile</key>
			<string>fizzy.icns</string>
			<key>CFBundleTypeName</key>
			<string>fizzy art files</string>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
		</dict>
		<!--
		  Wildcard entry so fizzy shows up in Finder's "Open With" for any file,
		  not just the extensions above. `LSHandlerRank: Alternate` means it never
		  contests an existing default for a given extension — the user still has
		  to explicitly pick "Open With > fizzy > Always Open With" per file type.
		  This is the same mechanism generic editors (VS Code, Sublime, BBEdit)
		  use to be settable-as-default for arbitrary/unknown extensions.
		-->
		<dict>
			<key>CFBundleTypeExtensions</key>
			<array>
				<string>*</string>
			</array>
			<key>CFBundleTypeIconFile</key>
			<string>fizzy.icns</string>
			<key>CFBundleTypeName</key>
			<string>All Documents</string>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>LSHandlerRank</key>
			<string>Alternate</string>
		</dict>
	</array>
</dict>
</plist>

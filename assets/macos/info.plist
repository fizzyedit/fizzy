	<key>CFBundleVersion</key>
	<string>0.1.0</string>
	<key>CFBundleIconFile</key>
	<string>fizzy.icns</string>
	<!--
	  Required for Gatekeeper / `spctl --assess` to recognise the bundle as an
	  application after notarisation. Without `CFBundlePackageType=APPL` +
	  `CFBundleExecutable`, vpk's post-notarise spctl check fails with
	  "the code is valid but does not seem to be an app".
	-->
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleExecutable</key>
	<string>fizzy</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>LSMinimumSystemVersion</key>
	<string>11.0</string>
	<key>NSHighResolutionCapable</key>
	<true/>
	<key>CFBundleDocumentTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeExtensions</key>
			<array>
				<string>fiz</string>
				<string>pixi</string>
			</array>
			<key>CFBundleTypeIconFile</key>
			<string>fizzy.icns</string>
			<key>CFBundleTypeName</key>
			<string>fizzy art files</string>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
		</dict>
		<dict>
			<key>CFBundleTypeExtensions</key>
			<array>
				<string>png</string>
				<string>jpg</string>
				<string>jpeg</string>
			</array>
			<key>CFBundleTypeIconFile</key>
			<string>fizzy.icns</string>
			<key>CFBundleTypeName</key>
			<string>Image files</string>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
		</dict>
		<!--
		  `CFBundleTypeExtensions: ["*"]` (the previous approach here) does NOT
		  make an app appear in Finder's "Open With" for arbitrary files on modern
		  macOS — verified empirically (LSCopyApplicationURLsForURL never returns
		  wildcard/public.data-only claimers for an unrecognized extension,
		  regardless of whether the claim is expressed via the "*" extension or
		  via LSItemContentTypes: public.data/public.item/public.content). Editors
		  that appear to "open anything" (VS Code, Cursor) actually just enumerate
		  a large explicit extension list. This list mirrors Cursor's
		  CFBundleDocumentTypes extension set so fizzy is a same-tier "Open With"
		  candidate for code/text/data files. `LSHandlerRank: Alternate` means it
		  never contests an existing default for a given extension.
		-->

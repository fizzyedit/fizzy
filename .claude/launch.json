{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "fizzy-web",
      "runtimeExecutable": "sh",
      "runtimeArgs": ["scripts/serve-web.sh"],
      "cwd": ".",
      "port": 8765
    },
    {
      "name": "fizzy-docs",
      "runtimeExecutable": "sh",
      "runtimeArgs": ["-c", "python3 -m http.server \"$PORT\" --directory docs"],
      "port": 8767,
      "autoPort": true
    }
  ]
}
